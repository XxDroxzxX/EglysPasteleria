PORT=3000

# Railway (app en la nube): usa MYSQL_URL interna o referencia variables de la BD.
# Desde tu PC: usa MYSQL_PUBLIC_URL como DATABASE_URL o MYSQL_URL en este archivo.

# Opción A: URL completa
# DATABASE_URL=mysql://...

# Opción B: variables sueltas (local)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=eglys_pasteleria
# DB_PORT=3306

# Solo si el proveedor lo exige (p. ej. algunos MySQL públicos)
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Configuración de WhatsApp para pedidos
# Número de WhatsApp de la pastelería (incluir código de país, sin + ni espacios)
# Ejemplo: 573015123456 para Colombia
WHATSAPP_PHONE_NUMBER=573015123456
